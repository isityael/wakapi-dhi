{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>m0sh1/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "enabledManagers": ["gomod", "dockerfile", "npm"],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "automerge": true,
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "Dockerfile base images",
      "labels": ["dependencies", "docker"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "Frontend dependencies",
      "labels": ["dependencies", "frontend"]
    },
    {
      "description": "Reduce abandonment false-positives for stable or low-churn upstream dependencies",
      "matchManagers": ["gomod"],
      "matchPackageNames": [
        "github.com/cespare/xxhash/v2",
        "github.com/dchest/captcha",
        "github.com/emersion/go-sasl",
        "github.com/go-chi/httprate",
        "github.com/gorilla/schema",
        "github.com/gorilla/securecookie",
        "github.com/gorilla/sessions",
        "github.com/mileusna/useragent",
        "github.com/oauth2-proxy/mockoidc",
        "github.com/robfig/cron/v3",
        "github.com/stripe/stripe-go/v76",
        "github.com/swaggo/http-swagger/v2",
        "gorm.io/driver/mysql",
        "gorm.io/driver/postgres",
        "gopkg.in/yaml.v3"
      ],
      "abandonmentThreshold": "5 years"
    }
  ]
}
